# CIDAS — CI Dependency Analysis & Screening
# Copy to .env and fill in values before starting the daemon.

# ── Daemon ────────────────────────────────────────────────────────────────────
DAEMON_HOST=127.0.0.1
DAEMON_PORT=7355
LOG_LEVEL=info                 # debug | info | warning | error

# ── Scoring thresholds (0–100, higher = riskier) ──────────────────────────────
BLOCK_THRESHOLD=80             # block install automatically
WARN_THRESHOLD=40              # show warning, allow install

# ── Pillar weights (must sum to 1.0) ──────────────────────────────────────────
CONTEXT_WEIGHT=0.30
SENTINEL_WEIGHT=0.35
SHIELD_WEIGHT=0.35

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=.cidas_chroma

# ── SQLite cache ──────────────────────────────────────────────────────────────
SQLITE_DB_PATH=.cidas_cache.db

# ── NPM Registry ──────────────────────────────────────────────────────────────
NPM_REGISTRY_URL=https://registry.npmjs.org

# ── Disk space checking ───────────────────────────────────────────────────────
# Set to false on constrained CI runners to skip npm-registry size lookups.
DISK_CHECK_ENABLED=true

# ── LLM Verification (Ollama) ─────────────────────────────────────────────────
# Optional second-pass check: asks a local Ollama model to evaluate README text
# that the regex scan flagged as possibly adversarial. Disabled by default because
# it requires Ollama to be installed and running locally. No API key is needed.
LLM_VERIFICATION_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# ── Concept drift monitoring ──────────────────────────────────────────────────
# Compares recent pillar score distributions against a seeded baseline.
# Set to false to skip the drift check in the /health response.
DRIFT_MONITORING_ENABLED=true
DRIFT_KL_WARN_THRESHOLD=0.15
DRIFT_KL_ALERT_THRESHOLD=0.30
