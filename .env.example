# CIDAS — CI Dependency Analysis & Screening
# Copy to .env and fill in values before starting the daemon.

# ── Daemon ────────────────────────────────────────────────────────────────────
DAEMON_HOST=127.0.0.1
DAEMON_PORT=7979
DAEMON_LOG_LEVEL=info          # debug | info | warning | error

# ── NPM Registry ──────────────────────────────────────────────────────────────
NPM_REGISTRY_URL=https://registry.npmjs.org
NPM_REGISTRY_TIMEOUT=10        # seconds per request
NPM_MAX_CONCURRENT=5           # concurrent registry fetches

# ── OSV / Vulnerability Feeds ─────────────────────────────────────────────────
OSV_API_URL=https://api.osv.dev/v1
OSV_TIMEOUT=10

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=.cidas_chroma

# ── SQLite Cache ──────────────────────────────────────────────────────────────
SQLITE_DB_PATH=.cidas_cache.db
CACHE_TTL_SECONDS=3600         # 1 hour

# ── Scoring thresholds ────────────────────────────────────────────────────────
# Risk score is 0–100; higher = riskier.
BLOCK_THRESHOLD=80             # block install automatically
WARN_THRESHOLD=40              # show warning, allow install

# ── Extension <-> Daemon auth ────────────────────────────────────────────────
# A random secret shared between the VS Code extension and the local daemon.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DAEMON_SECRET=CHANGE_ME
